# =============================================================================
# Witches & Snitches - Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in the values:
#     cp .env.example .env
#
# All variables are read at BUILD time by Create React App, so they MUST be
# prefixed with REACT_APP_. Restart `npm start` after changing any value.
# =============================================================================

# --- Supabase (REQUIRED) -----------------------------------------------------
# The app throws on startup if these two are missing (see src/lib/supabase.js).
# Find them in your Supabase project: Settings -> API.
REACT_APP_SUPABASE_URL=https://your-project-ref.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your_supabase_anon_public_key

# --- Admin (optional) --------------------------------------------------------
# Gate for the in-app admin tools (see src/services/characterService.js).
REACT_APP_ADMIN_PASSWORD=

# --- Sentry (optional; only initialized when NODE_ENV=production) ------------
# Leave blank for local development.
REACT_APP_SENTRY_DSN=

# --- Discord roll webhooks (optional) ----------------------------------------
# One webhook URL per game session. Dice rolls are posted to the channel that
# matches the character's game session; FALLBACK is used when no match is found.
# See src/App/const.js. Any you leave blank simply won't post for that session.
# For local dev you generally only need DEVELOPMENT and/or FALLBACK.
REACT_APP_DISCORD_WEBHOOK_DEVELOPMENT=
REACT_APP_DISCORD_WEBHOOK_FALLBACK=
REACT_APP_DISCORD_WEBHOOK_ONE_SHOT=
REACT_APP_DISCORD_WEBHOOK_MONDAY_HAUNTING=
REACT_APP_DISCORD_WEBHOOK_TUESDAY_HAUNTING=
REACT_APP_DISCORD_WEBHOOK_WEDNESDAY_HAUNTING=
REACT_APP_DISCORD_WEBHOOK_FRIDAY_HAUNTING=
REACT_APP_DISCORD_WEBHOOK_SATURDAY_HAUNTING=
REACT_APP_DISCORD_WEBHOOK_WEDNESDAY_KNIGHTS=
REACT_APP_DISCORD_WEBHOOK_FRIDAY_KNIGHTS=
REACT_APP_DISCORD_WEBHOOK_SATURDAY_KNIGHTS_AM=
REACT_APP_DISCORD_WEBHOOK_SATURDAY_KNIGHTS_PM=

# =============================================================================
# NOTE on Discord login: Discord authentication is handled by Supabase Auth
# (Supabase Dashboard -> Authentication -> Providers -> Discord), NOT by env
# vars in this app. There is no REACT_APP_DISCORD_CLIENT_ID / REDIRECT_URI.
# =============================================================================
